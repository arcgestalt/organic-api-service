    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "dependencies": {
    "@axiomhq/js": "^1.8.0",
    "@libsql/client": "^0.17.4",
    "@sentry/browser": "^10.65.0",
    "@sentry/integrations": "^7.114.0",
    "@sentry/node": "^10.65.0",
